{
  "name": "agent-skills",
  "displayName": "Agent Skills",
  "description": "Discover, install, and manage AI agent skills directly within VS Code",
  "version": "0.0.1",
  "publisher": "tech-leads-club",
  "author": "Tech Leads Club",
  "license": "MIT",
  "icon": "resources/icon.png",
  "homepage": "https://github.com/tech-leads-club/agent-skills/tree/main/packages/ide-extension",
  "bugs": {
    "url": "https://github.com/tech-leads-club/agent-skills/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "copilot",
    "cursor",
    "claude"
  ],
  "repository": {
    "directory": "packages/ide-extension",
    "type": "git",
    "url": "git+https://github.com/tech-leads-club/agent-skills.git"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "resources/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22",
    "vscode": "^1.96.0"
  },
  "activationEvents": [],
  "categories": [
    "Other"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-skills-sidebar",
          "title": "Agent Skills",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "agent-skills-sidebar": [
        {
          "type": "webview",
          "id": "agentSkillsSidebar",
          "name": "Agent Skills",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": []
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In restricted mode, only marketplace browsing is available. Local skill installation is disabled."
    }
  },
  "scripts": {
    "build": "nx build ide-extension",
    "build:webview": "nx run ide-extension:build:webview",
    "lint": "nx run ide-extension:lint",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' nx run ide-extension:test",
    "test:integration": "node ./scripts/run-integration-tests.mjs",
    "typecheck": "tsc --noEmit",
    "package": "nx run ide-extension:package",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@tech-leads-club/core": "0.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "jest-axe": "^9.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22",
    "@types/vscode": "^1.96.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/codicons": "^0.0.44",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "fuse.js": "^7.1.0",
    "glob": "^10.5.0",
    "mocha": "^11.7.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}
