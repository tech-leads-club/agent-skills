{
  "name": "ide-extension",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ide-extension/src",
  "projectType": "application",
  "tags": ["scope:ide-extension"],
  "targets": {
    "build:webview": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist/webview"],
      "inputs": ["production", "^production"],
      "options": {
        "command": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\" && npx vite build",
        "cwd": "packages/ide-extension"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:webview", "^build"],
      "outputs": ["{projectRoot}/dist"],
      "defaultConfiguration": "production",
      "inputs": ["production", "^production"],
      "options": {
        "command": "npx tsc -p tsconfig.lib.json --noEmit && node ./scripts/build-extension.mjs",
        "cwd": "packages/ide-extension"
      },
      "configurations": {
        "development": {
          "command": "npx tsc -p tsconfig.lib.json --noEmit && node ./scripts/build-extension.mjs"
        },
        "production": {
          "command": "npx tsc -p tsconfig.lib.json --noEmit && node ./scripts/build-extension.mjs --production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/ide-extension/jest.config.ts"
      },
      "env": {
        "NODE_OPTIONS": "--experimental-vm-modules"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "^production"],
      "outputs": ["{options.outputFile}"],
      "options": {
        "command": "eslint . --ignore-pattern .vscode-test",
        "cwd": "packages/ide-extension"
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @vscode/vsce package --no-dependencies",
        "cwd": "packages/ide-extension"
      }
    }
  }
}
